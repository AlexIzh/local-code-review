{
	"name": "local-code-review",
	"version": "0.1.0",
	"description": "Local code review tool — GitHub PR-like diff view with inline comments for AI-assisted development",
	"type": "module",
	"bin": {
		"local-code-review": "./bin/lcr.js",
		"lcr": "./bin/lcr.js"
	},
	"files": [
		"bin/",
		"build/"
	],
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"prepublishOnly": "npm run build",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.2",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/ws": "^8.18.1",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"diff2html": "^3.4.56",
		"node-pty": "^1.2.0-beta.12",
		"open": "^11.0.0",
		"shiki": "^4.0.2",
		"simple-git": "^3.33.0",
		"ws": "^8.20.0"
	}
}
